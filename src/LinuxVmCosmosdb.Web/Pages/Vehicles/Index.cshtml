@page
@model LinuxVmCosmosdb.Web.Pages.Vehicles.IndexModel
@{
    ViewData["Title"] = "Fleet";
}

<div class="container mt-4">
    <h2>Fleet Management</h2>
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Plate</th>
                <th>Type</th>
                <th>Driver</th>
                <th>Location</th>
                <th>Capacity (kg)</th>
                <th>Mileage (km)</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var v in Model.Vehicles)
            {
                <tr>
                    <td>@v.PlateNumber</td>
                    <td>@v.Type</td>
                    <td>@v.DriverName</td>
                    <td>@v.CurrentLocation</td>
                    <td>@v.CapacityKg.ToString("N0")</td>
                    <td>@v.MileageKm.ToString("N0")</td>
                    <td>
                        <span class="badge @(v.Status switch {
                            "InTransit" => "text-bg-warning",
                            "Available" => "text-bg-success",
                            "Maintenance" => "text-bg-danger",
                            _ => "text-bg-light"
                        })">@v.Status</span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
