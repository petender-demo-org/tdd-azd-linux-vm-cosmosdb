<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Logistics Tracker</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" asp-page="/Index">🚛 Logistics Tracker</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" asp-page="/Index">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Shipments/Index">Shipments</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Vehicles/Index">Fleet</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Routes/Index">Routes</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="container mt-5 mb-3 text-muted text-center">
        <small>Logistics Tracker &mdash; Azure Cosmos DB + .NET 10 Demo</small>
    </footer>
</body>
</html>
