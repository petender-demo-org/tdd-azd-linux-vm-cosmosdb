@page
@model LinuxVmCosmosdb.Web.Pages.Shipments.IndexModel
@{
    ViewData["Title"] = "Shipments";
}

<div class="container mt-4">
    <h2>All Shipments</h2>
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Tracking #</th>
                <th>Customer</th>
                <th>Origin</th>
                <th>Destination</th>
                <th>Weight (kg)</th>
                <th>Status</th>
                <th>Created</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model.Shipments)
            {
                <tr>
                    <td><a asp-page="Details" asp-route-id="@s.Id">@s.TrackingNumber</a></td>
                    <td>@s.CustomerName</td>
                    <td>@s.Origin</td>
                    <td>@s.Destination</td>
                    <td>@s.WeightKg</td>
                    <td><span class="badge @Model.GetStatusBadge(s.Status)">@s.Status</span></td>
                    <td>@s.CreatedAt.ToString("yyyy-MM-dd")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
